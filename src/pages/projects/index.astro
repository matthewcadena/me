---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";

const entries = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order
);

const rendered = await Promise.all(
  entries.map(async (entry) => ({
    entry,
    Content: (await render(entry)).Content,
  }))
);
---

<Base
  title="Projects — Matt Cadena"
  description="Projects by Matt Cadena, from notification personalization at Nextdoor to a custom memory allocator."
>
  <h1>Projects</h1>

  {
    rendered.map(({ entry, Content }) => (
      <details class="project">
        <summary>
          <span class="project-title">{entry.data.title}</span>
          {entry.data.year && (
            <span class="project-year">{entry.data.year}</span>
          )}
        </summary>
        <div class="project-body">
          {entry.data.image && (
            <img
              src={entry.data.image}
              alt={entry.data.imageAlt ?? entry.data.title}
              loading="lazy"
            />
          )}
          <Content />
          <p class="project-link">
            <a
              href={entry.data.link}
              target={entry.data.link.startsWith("http") ? "_blank" : undefined}
              rel={
                entry.data.link.startsWith("http")
                  ? "noopener noreferrer"
                  : undefined
              }
            >
              {entry.data.linkText}
            </a>
          </p>
        </div>
      </details>
    ))
  }
</Base>
