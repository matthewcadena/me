---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";

const entries = (await getCollection("work")).sort(
  (a, b) => a.data.order - b.data.order
);

const rendered = await Promise.all(
  entries.map(async (entry) => ({
    entry,
    Content: (await render(entry)).Content,
  }))
);
---

<Base
  title="work"
  description="Matt Cadena's work experience: Nextdoor, Ford, and CMU's Institute for Strategy & Technology."
>
  <h1>work</h1>

  <p class="page-intro">
    Over the past few years, I've gained valuable experience in both industry
    and academia. I've completed internships at Nextdoor and Ford Motor Company in the summers 
    of 2025 and 2024, respectively. During my time at CMU, I held positions as a teaching assistant 
    for 15-210: Parallel and Sequential Data Structures and Algorithms, and as a research assistant 
    in the Institute for Strategy & Technology.
  </p>

  {
    rendered.map(({ entry, Content }) => (
      <article class="work-entry">
        <div class="work-period">{entry.data.period}</div>
        <div class="work-body">
          <h2>
            {entry.data.title}{" "}
            <span class="company"> | {entry.data.company}</span>
          </h2>
          <Content />
          <p class="work-tags">{entry.data.tags.join(" · ")}</p>
        </div>
      </article>
    ))
  }
</Base>
